---
{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
{% set container_port = 8080 %}  
  {{ application_id | get_entity_name }}:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'mini-qr') }}
    {{ lookup('compose_only', 'container_name', MINI_QR_CONTAINER) }}
    ports:
      - {{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.mini-qr.ports.local.http') }}:{{ container_port }}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id) }}

{{ lookup('compose_networks') }}
