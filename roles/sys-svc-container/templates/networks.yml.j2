{# This template needs to be included in compose.yml containers #}
{% set _registry = query('service_registry') | first %}
{% set _ns = namespace(att=[], default_aliases=[]) %}
{% for _service_key, _entry in _registry.items() %}
{%   if 'canonical' not in _entry %}
{%     set _overlay = _entry.get('overlay') %}
{%     if _overlay and DEPLOYMENT_MODE in _overlay.modes %}
{%       set _is_provider = application_id == _entry.role %}
{%       set _is_consumer = false %}
{%       set _topology = _overlay.get('topology') %}
{%       if (not _is_provider) and _topology %}
{%         set _consumer = _overlay.get('consumer', {}) %}
{%         set _kind = _consumer.get('kind') or 'services_flags' %}
{%         if _kind == 'database' %}
{%           set _is_consumer = (lookup('database', application_id, 'enabled') | bool)
                              and (lookup('database', application_id, 'shared') | bool)
                              and (lookup('database', application_id, 'id') == _entry.role) %}
{%         elif _kind == 'services_flags' %}
{%           set _key = _consumer.get('key') or _entry.get('provides') or _entry.entity_name %}
{%           set _flags = _consumer.get('flags') or ['enabled', 'shared'] %}
{%           set _flags_ns = namespace(ok=true) %}
{%           for _flag in _flags %}
{%             if not (lookup('config', application_id, 'services.' ~ _key ~ '.' ~ _flag, False) | bool) %}
{%               set _flags_ns.ok = false %}
{%             endif %}
{%           endfor %}
{%           set _is_consumer = _flags_ns.ok %}
{%         endif %}
{%       endif %}
{%       if _is_provider %}
{%         if _topology == 'default_net' %}
{%           set _own_aliases = _overlay.get('aliases', []) %}
{%           for _alias in _own_aliases %}
{%             set _ = _ns.default_aliases.append(_alias) %}
{%           endfor %}
{%           for _peer_key, _peer in _registry.items() %}
{%             set _peer_overlay = _peer.get('overlay') %}
{%             if _peer_overlay
                  and _peer_overlay.get('proxy_resolvable')
                  and DEPLOYMENT_MODE in _peer_overlay.modes
                  and 'canonical' not in _peer
                  and _peer.role != _entry.role %}
{%               for _alias in _peer_overlay.aliases | default([]) %}
{%                 set _ = _ns.default_aliases.append(_alias) %}
{%               endfor %}
{%             endif %}
{%           endfor %}
{%         elif _topology %}
{%           set _own_aliases = _overlay.get('aliases', [_entry.entity_name]) %}
{%           set _ = _ns.att.append({'role': _entry.role, 'aliases': _own_aliases}) %}
{%         endif %}
{%       elif _is_consumer %}
{%         set _ = _ns.att.append({'role': _entry.role, 'aliases': []}) %}
{%       endif %}
{%     endif %}
{%   endif %}
{% endfor %}
    networks:
{% for _a in _ns.att %}
      {{ _a.role | get_entity_name }}:
{%   if _a.aliases %}
        aliases:
{%     for _alias in _a.aliases %}
          - {{ _alias }}
{%     endfor %}
{%   else %}
        {}
{%   endif %}
{% endfor %}
{% set _suppress_default = application_id.startswith('svc-db-') or application_id.startswith('svc-ai-') %}
{% if not _suppress_default %}
{% if _ns.default_aliases %}
      default:
        aliases:
{% for _alias in _ns.default_aliases %}
          - {{ _alias }}
{% endfor %}
{% else %}
      default:
{% endif %}
{% endif %}
{{ "\n" }}
