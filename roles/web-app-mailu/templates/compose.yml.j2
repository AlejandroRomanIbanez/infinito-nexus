{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  resolver:
{% set service_name = 'resolver' %}
    {{ lookup('container_image', application_id, 'resolver', image=MAILU_DOCKER_FLAVOR ~ '/unbound', version=MAILU_VERSION) }}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_resolver') }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
        ipv4_address: {{ MAILU_DNS_RESOLVER }}

  {{ MAILU_FRONT_SERVICE }}:
{% set service_name = MAILU_FRONT_SERVICE %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_' ~ MAILU_FRONT_SERVICE) }}
    {{ lookup('container_image', application_id, 'front', image=MAILU_DOCKER_FLAVOR ~ '/nginx', version=MAILU_VERSION) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.mailu.ports.local.http') }}:80"
      - "{{ MAILU_IP4_PUBLIC }}:25:25"
      - "{{ MAILU_IP4_PUBLIC }}:465:465"
      - "{{ MAILU_IP4_PUBLIC }}:587:587"
      - "{{ MAILU_IP4_PUBLIC }}:110:110"
      - "{{ MAILU_IP4_PUBLIC }}:995:995"
      - "{{ MAILU_IP4_PUBLIC }}:143:143"
      - "{{ MAILU_IP4_PUBLIC }}:993:993"
      - "{{ MAILU_IP4_PUBLIC }}:4190:4190"
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{{ lookup('container_depends_on', application_id, extra={
  'resolver': {'condition': 'service_started'},
}) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      webmail:
      radicale:
    dns:
      - {{ MAILU_DNS_RESOLVER }}

  admin:
{% set service_name = 'admin' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_admin') }}
    {{ lookup('container_image', application_id, 'admin', image=MAILU_DOCKER_FLAVOR ~ '/admin', version=MAILU_VERSION) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{{ lookup('container_depends_on', application_id, extra={
  'resolver': {'condition': 'service_started'},
  'front': {'condition': 'service_started'},
}) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}

{% if ( DOCKER_IN_CONTAINER | bool ) and ( MAILU_OIDC_ENABLED | bool ) %}
    extra_hosts:
      - "{{ MAILU_OIDC_HOST }}:host-gateway"
{% endif %}

{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  imap:
{% set service_name = 'imap' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_imap') }}
    {{ lookup('container_image', application_id, 'imap', image=MAILU_DOCKER_FLAVOR ~ '/dovecot', version=MAILU_VERSION) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('depends_on', ['front', 'resolver']) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  smtp:
{% set service_name = 'smtp' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_smtp') }}
    {{ lookup('container_image', application_id, 'smtp', image=MAILU_DOCKER_FLAVOR ~ '/postfix', version=MAILU_VERSION) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('depends_on', ['front', 'resolver']) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  oletools:
{% set service_name = 'oletools' %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_oletools') }}
    {{ lookup('container_image', application_id, 'oletools', image=MAILU_DOCKER_FLAVOR ~ '/oletools', version=MAILU_VERSION) }}
    hostname: oletools
    {{ lookup('depends_on', ['resolver']) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      noinet:

  antispam:
{% set service_name = 'antispam' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_antispam') }}
    {{ lookup('container_image', application_id, 'antispam', image=MAILU_DOCKER_FLAVOR ~ '/rspamd', version=MAILU_VERSION) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('depends_on', ['front', 'redis', 'antivirus', 'resolver']) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      noinet:  

  antivirus:
{% set service_name = 'antivirus' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_antivirus') }}
    {{ lookup('container_image', application_id, 'antivirus') }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('depends_on', ['resolver']) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  webdav:
{% set service_name = 'webdav' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_webdav') }}
    {{ lookup('container_image', application_id, 'webdav', image=MAILU_DOCKER_FLAVOR ~ '/radicale', version=MAILU_VERSION) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('depends_on', ['resolver']) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      radicale:

  fetchmail:
{% set service_name = 'fetchmail' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_fetchmail') }}
    {{ lookup('container_image', application_id, 'fetchmail', image=MAILU_DOCKER_FLAVOR ~ '/fetchmail', version=MAILU_VERSION) }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('depends_on', ['admin', 'smtp', 'imap', 'resolver']) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  webmail:
{% set service_name = 'webmail' %}
    {{ lookup('compose_only', 'container_name', MAILU_CONTAINER ~ '_webmail') }}
    {{ lookup('container_image', application_id, 'webmail', image=MAILU_DOCKER_FLAVOR ~ '/webmail', version=MAILU_VERSION) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('depends_on', ['imap', 'front', 'resolver']) }}
    dns:
      - {{ MAILU_DNS_RESOLVER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      webmail:

{{ lookup('compose_volumes', application_id,
    extra_volumes={'admin_data': {'name': MAILU_ADMIN_DATA_VOLUME}, 'clamav_db': {'name': MAILU_CLAMAV_DB_VOLUME}, 'dkim': {'name': MAILU_DKIM_VOLUME}, 'dovecot_mail': {'name': MAILU_DOVECOT_MAIL_VOLUME}, 'filter': {'name': MAILU_FILTER_VOLUME}, 'smtp_queue': {'name': MAILU_SMTP_QUEUE_VOLUME}, 'webdav_data': {'name': MAILU_WEBDAV_DATA_VOLUME}, 'webmail_data': {'name': MAILU_WEBMAIL_DATA_VOLUME}}
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
{% if DEPLOYMENT_MODE == 'swarm' %}
  radicale:
    driver: overlay
    attachable: true
  webmail:
    driver: overlay
    attachable: true
  noinet:
    driver: overlay
    attachable: true
    internal: true
{% else %}
  radicale:
    driver: bridge
  webmail:
    driver: bridge
  noinet:
    driver: bridge
    internal: true
{% endif %}
